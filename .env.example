GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-lite-latest
SECRET_KEY=your_secret_key_here_change_this
USDA_API_KEY=DEMO_KEY

# Firebase / Firestore (used on Vercel — omit to use local SQLite instead)
# Paste the minified JSON of your Firebase service-account key here:
# FIREBASE_CREDENTIALS={"type":"service_account","project_id":"..."}

# SQLite fallback (local dev / tests only — ignored when FIREBASE_CREDENTIALS is set)
DATABASE_URL=sqlite:///chefbuilder.db
